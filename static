<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Its A Little Sketchy - Video Gallery (Placeholder)</title>
  <style>
    body { font-family: Arial, Helvetica, sans-serif; margin: 1rem; }
    .tile { max-width: 900px; margin: 1rem auto; border: 1px solid #ddd; padding: 1rem; text-align: center; }
    .thumb { width: 100%; height: auto; max-height: 480px; object-fit: cover; background:#eee; display:block; margin-bottom:0.5rem; }
    .btn { display:inline-block; padding:0.6rem 1rem; background:#1e88e5; color:#fff; border-radius:4px; text-decoration:none; cursor:pointer; }
    .note { color:#666; font-size:0.9rem; margin-top:0.75rem; }
  </style>
</head>
<body>
  <h1>Video Gallery (Placeholder)</h1>

  <!-- Example single tile — replace VILOUD_EMBED_URL_HERE with the Viloud embed URL for your video or channel -->
  <div class="tile" id="video-tile-1">
    <img class="thumb" id="poster-1" alt="Thumbnail" src="" />
    <div>
      <button class="btn" id="play-1">Load Player</button>
    </div>
    <div class="note">
      This placeholder will lazy‑load the Viloud player when you click "Load Player". You can replace VILOUD_EMBED_URL_HERE below with the Viloud embed URL or iframe that Viloud provides.
    </div>
  </div>

  <script>
    // Replace this string with Viloud's embed URL or iframe src when ready.
    const VILOUD_EMBED_URL = "VILOUD_EMBED_URL_HERE";

    document.getElementById('play-1').addEventListener('click', function () {
      const container = document.getElementById('video-tile-1');
      // Insert iframe — update width/height as needed
      container.innerHTML = '<iframe src="' + VILOUD_EMBED_URL + '" width="100%" height="480" frameborder="0" allowfullscreen></iframe>';
    });

    // Optional: show a simple generated poster until you replace with real thumbnail
    document.getElementById('poster-1').src = 'data:image/svg+xml;utf8,' +
      encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="1280" height="720"><rect width="100%" height="100%" fill="#ddd"/><text x="50%" y="50%" font-size="28" dominant-baseline="middle" text-anchor="middle" fill="#777">Click "Load Player" to play</text></svg>');
  </script>
</body>
</html>
